# Meta Graph API
META_API_VERSION=v23.0

# Google Places API (New) — konum autocomplete için
GOOGLE_MAPS_API_KEY=

# Veritabanı — Vercel + Neon'da otomatik eklenir
# Yerel geliştirmede Neon bağlantısı veya dosya tabanlı depolama kullanılır
POSTGRES_URL=
DATABASE_URL=
